{
  "name": "@barchart/events-client-js",
  "version": "6.0.0",
  "description": "JavaScript SDK for Barchart's Event Tracking Service",
  "author": {
    "name": "Bryan Ingle",
    "email": "bryan.ingle@barchart.com",
    "url": "https://www.barchart.com"
  },
  "contributors": [
    {
      "name": "Igor Losev",
      "email": "igor.losev@barchart.com"
    },
    {
      "name": "Luka Sotra",
      "email": "luka.sotra@barchart.com"
    }
  ],
  "scripts": {
    "build": "node tools/build-examples.js",
    "deploy:examples": "node tools/deploy.js examples",
    "deploy:documentation": "node tools/deploy.js documentation",
    "embed-version": "node tools/embed-version.js",
    "lint": "jshint ./ --exclude 'node_modules,example/browser/example*.js,docs'",
    "test": "jasmine --config=test/jasmine.json",
    "postversion": "yarn deploy:examples && yarn deploy:documentation",
    "version": "yarn embed-version && yarn build",
    "watch": "node tools/build-examples.js --watch"
  },
  "dependencies": {
    "@barchart/common-js": "^5.1.0",
    "@barchart/events-api-common": "^6.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/credential-providers": "^3.1093.0",
    "esbuild": "^0.28.1",
    "jasmine": "^4.5.0",
    "jshint": "^2.12.0"
  },
  "license": "MIT"
}
